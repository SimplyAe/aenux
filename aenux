# ───────────────────────────────────────────────────────────────────────
# MENU: BACKUP & RESTORE
# ───────────────────────────────────────────────────────────────────────
menu_backup() {
    while true; do
        banner
        draw_menu "💾  Backup & Restore" \
            "${G}1)${NC}  Backup package list" \
            "${Y}2)${NC}  Restore packages from list" \
            "${C}3)${NC}  Backup a directory (tar.gz)" \
            "${B}4)${NC}  Quick home folder backup" \
            "${M}5)${NC}  View saved backups" \
            "${R}6)${NC}  Delete old backups" \
            "${GR}0)${NC}  Back"
        prompt_choice

        case "$CHOICE" in
            1) backup_state; ok "Package list saved to $BACKUP_DIR" ;;
            2) restore_packages ;;
            3) prompt_input "Directory to backup (full path)"
               local src="$INPUT"
               [[ ! -d "$src" ]] && { fail "Directory not found."; pause; continue; }
               local dest="$BACKUP_DIR/dir-$(date +%Y%m%d-%H%M%S).tar.gz"
               run_spin "Backing up $src..." tar czf "$dest" "$src" 2>/dev/null
               ok "Saved to: $dest"; hist "backup-dir: $src" ;;
            4) local dest="$BACKUP_DIR/home-$(date +%Y%m%d-%H%M%S).tar.gz"
               confirm "Backup $HOME (excluding .cache and Trash)?" || { pause; continue; }
               run_spin "Backing up home..." tar czf "$dest" \
                   --exclude="$HOME/.cache" --exclude="$HOME/.local/share/Trash" "$HOME" 2>/dev/null
               ok "Home backed up to: $dest"; hist "backup-home" ;;
            5) echo ""
               ls -lh "$BACKUP_DIR" 2>/dev/null | awk '{print "  "$0}' || info "No backups found." ;;
            6) confirm "Delete ALL backups in $BACKUP_DIR?" || { pause; continue; }
               rm -rf "${BACKUP_DIR:?}"/* && ok "Backups cleared." || fail "Failed." ;;
            0) return ;;
            *) warn "Invalid choice." ;;
        esac
        pause
    done
}

backup_state() {
    local pm; pm=$(detect_pm)
    local ts; ts=$(date +%Y%m%d-%H%M%S)
    local file="$BACKUP_DIR/pkglist-$ts.txt"
    case "$pm" in
        apt-get)      dpkg --get-selections > "$file" ;;
        dnf|yum)      rpm -qa > "$file" ;;
        pacman)       pacman -Qqe > "$file" ;;
        apk)          apk list --installed 2>/dev/null > "$file" ;;
        xbps-install) xbps-query -l > "$file" ;;
        nix-env)      nix-env -q > "$file" ;;
        *)            warn "Package list backup not supported for $pm"; return ;;
    esac
    ok "Package list saved: $file"
    log INFO "Package list backup: pkglist-$ts.txt"
}

restore_packages() {
    info "Available package lists in $BACKUP_DIR:"
    ls "$BACKUP_DIR"/pkglist-*.txt 2>/dev/null | awk '{print "  "$0}' || { warn "No package lists found."; return; }
    prompt_input "Full path to package list file"
    local file="$INPUT"
    [[ ! -f "$file" ]] && { fail "File not found: $file"; return; }
    need_root
    local pm; pm=$(detect_pm)
    confirm "Reinstall all packages from $file?" || return
    case "$pm" in
        apt-get) dpkg --set-selections < "$file" && apt-get dselect-upgrade -y ;;
        pacman)  sudo pacman -S --needed --noconfirm $(cat "$file") ;;
        *)       warn "Auto-restore not supported for $pm. Use the list manually." ;;
    esac
    ok "Restore completed."; hist "restore-packages: $file"
}

# ───────────────────────────────────────────────────────────────────────
# MENU: SYSTEM HEALTH
# ───────────────────────────────────────────────────────────────────────
menu_health() {
    banner
    echo -e "  ${C}${BOLD}System Health Report${NC}  ${DIM}$(date '+%Y-%m-%d %H:%M:%S')${NC}\n"

    # Uptime & Load
    echo -e "  ${BOLD}Uptime:${NC}   $(uptime -p 2>/dev/null || uptime)"
    local load; load=$(awk '{print "1m="$1"  5m="$2"  15m="$3}' /proc/loadavg)
    echo -e "  ${BOLD}Load:${NC}     $load\n"

    # Memory bar
    echo -e "  ${BOLD}Memory:${NC}"
    free -h | awk 'NR<=2{printf "  %-10s %s\n", $1, $0}'; echo ""

    # Disk (color-coded, real mounts only)
    echo -e "  ${BOLD}Disk Usage:${NC}"
    df -h --output=target,fstype,size,used,avail,pcent 2>/dev/null | \
        grep -Ev "^(tmpfs|devtmpfs|squashfs|efivarfs|cgroupfs|sysfs|proc|devpts|hugetlbfs|mqueue|debugfs|tracefs|securityfs|fusectl|binfmt_misc|configfs|none|Filesystem)" | \
        while IFS= read -r line; do
            local pct; pct=$(echo "$line" | awk '{gsub(/%/,"",$6); print $6+0}')
            if   [[ $pct -ge 90 ]]; then echo -e "  ${R}$line${NC}"
            elif [[ $pct -ge 70 ]]; then echo -e "  ${Y}$line${NC}"
            else echo "  $line"; fi
        done; echo ""

    # Updates
    echo -e "  ${BOLD}Pending Updates:${NC}"
    local count; count=$(pm_run check 2>/dev/null | tr -d '[:space:]')
    [[ "$count" == "0" ]] && echo -e "  ${OK}  Up to date" || echo -e "  ${WARN}  ${Y}$count package(s) available${NC}"
    echo ""

    # Failed services
    if command -v systemctl &>/dev/null; then
        echo -e "  ${BOLD}Failed Services:${NC}"
        local fails; fails=$(systemctl --failed --no-pager --no-legend 2>/dev/null)
        [[ -z "$fails" ]] && echo -e "  ${OK}  None" || echo "$fails" | awk '{print "  "$0}'
        echo ""
    fi

    # Top 5 CPU consumers
    echo -e "  ${BOLD}Top Processes by CPU:${NC}"
    ps aux --sort=-%cpu 2>/dev/null | awk 'NR>=2 && NR<=7 {printf "  %-20s %5s%%  %5sMB\n", $11, $3, int($6/1024)}'
    echo ""

    # Top 5 memory consumers
    echo -e "  ${BOLD}Top Processes by Memory:${NC}"
    ps aux --sort=-%mem 2>/dev/null | awk 'NR>=2 && NR<=7 {printf "  %-20s %5s%%  %5sMB\n", $11, $4, int($6/1024)}'
    echo ""

    hist "health-check"
    pause
}

