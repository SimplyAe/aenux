VERSION="1.0.0"
SCRIPT_PATH="$(realpath "$0")"
SCRIPT="aenux"
CONFIG_DIR="$HOME/.config/aenux"
CONFIG_FILE="$CONFIG_DIR/config.conf"
HISTORY_FILE="$CONFIG_DIR/history.log"
LOGFILE="$CONFIG_DIR/aenux.log"
BACKUP_DIR="$HOME/.aenux-backups"
AENUX_REMOTE="https://raw.githubusercontent.com/aenux/aenux/main/aenux"

# ───────────────────────────────────────────────────────────────────────
# COLORS & SYMBOLS
# ───────────────────────────────────────────────────────────────────────
R='\033[0;31m';  G='\033[0;32m';  Y='\033[1;33m';  B='\033[0;34m'
M='\033[0;35m';  C='\033[0;36m';  W='\033[1;37m';  GR='\033[0;90m'
BOLD='\033[1m';  DIM='\033[2m';   NC='\033[0m'
OK="${G}✓${NC}"; FAIL="${R}✗${NC}"; ARR="${C}›${NC}"
WARN="${Y}⚠${NC}"; BULLET="${B}•${NC}"

# ───────────────────────────────────────────────────────────────────────
# CORE HELPERS
# ───────────────────────────────────────────────────────────────────────
trap 'tput cnorm 2>/dev/null; echo ""' EXIT INT TERM

log()       { mkdir -p "$CONFIG_DIR"; echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$1] ${*:2}" >> "$LOGFILE" 2>/dev/null; }
hist()      { mkdir -p "$CONFIG_DIR"; echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$HISTORY_FILE" 2>/dev/null; }
ok()        { echo -e "  ${OK}  ${G}${*}${NC}"; log INFO "$*"; }
fail()      { echo -e "  ${FAIL}  ${R}${*}${NC}"; log ERROR "$*"; }
info()      { echo -e "  ${ARR}  ${C}${*}${NC}"; }
warn()      { echo -e "  ${WARN}  ${Y}${*}${NC}"; log WARN "$*"; }
die()       { fail "$*"; exit 1; }
pause()     { echo; read -rp "$(echo -e "  ${DIM}Press Enter to continue...${NC}")"; }
confirm()   { read -rp "$(echo -e "  ${Y}$* [y/N]: ${NC}")" _r; [[ "${_r,,}" == "y" ]]; }
need_root() { [[ $EUID -ne 0 ]] && die "Root required. Run: sudo $SCRIPT"; }

prompt_choice() {
    echo -ne "\n  ${C}${BOLD}AENUX ${GR}›${NC} ${W}"
    read -r CHOICE
    echo -ne "${NC}"
}

prompt_input() {
    echo -ne "  ${Y}$1:${NC} ${W}"
    read -r INPUT
    echo -ne "${NC}"
}

spinner() {
    local pid=$1 msg="${2:-Working...}" sp='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏' i=0
    tput civis 2>/dev/null
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${C}${sp:$((i % ${#sp})):1}${NC}  ${DIM}%s${NC}   " "$msg"
        sleep 0.08; ((i++))
    done
    printf "\r%60s\r" ""; tput cnorm 2>/dev/null
}

run_spin() {
    local msg="$1"; shift
    "$@" &>/tmp/aenux_out.log &
    local pid=$!
    spinner "$pid" "$msg"
    wait "$pid"; local rc=$?
    [[ $rc -ne 0 ]] && { fail "Task failed. Log: /tmp/aenux_out.log"; return $rc; }
    return 0
}

# ───────────────────────────────────────────────────────────────────────
# CONFIG & INIT
# ───────────────────────────────────────────────────────────────────────
DEFAULT_EDITOR="nano"
DEFAULT_SHELL="/bin/bash"
DEFAULT_THEME="default"
BACKUP_BEFORE_UPGRADE="true"
AUTO_CLEAN="true"
SHOW_TIPS="true"
BACKUP_LOCATION="$HOME/.aenux-backups"
DRY_RUN="false"

init() {
    mkdir -p "$CONFIG_DIR" "$BACKUP_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        write_default_config
        first_run_wizard
    else
        source "$CONFIG_FILE" 2>/dev/null || true
    fi
    BACKUP_DIR="${BACKUP_LOCATION:-$HOME/.aenux-backups}"
    mkdir -p "$BACKUP_DIR"
}

write_default_config() {
    cat > "$CONFIG_FILE" << EOF
# AENUX Configuration - edit via Settings menu or directly
BACKUP_BEFORE_UPGRADE=true
AUTO_CLEAN=true
SHOW_TIPS=true
DRY_RUN=false
DEFAULT_EDITOR=nano
DEFAULT_SHELL=/bin/bash
DEFAULT_THEME=default
BACKUP_LOCATION=$HOME/.aenux-backups
EOF
}

reload_config() { source "$CONFIG_FILE" 2>/dev/null || true; }

# ───────────────────────────────────────────────────────────────────────
# FIRST-RUN WIZARD
# ───────────────────────────────────────────────────────────────────────
first_run_wizard() {
    clear
    echo -e "${C}${BOLD}"
    echo "  ╔══════════════════════════════════════════════════════╗"
    echo "  ║         Welcome to AENUX v${VERSION}                      ║"
    echo "  ║         First-time setup wizard                      ║"
    echo "  ╚══════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo -e "  Let's configure AENUX for your system.\n"

    # Editor
    echo -e "  ${BOLD}Preferred text editor:${NC}"
    echo -e "  ${GR}1) code (VS Code)  2) nano  3) vim  4) nvim  5) vi  6) micro  7) other${NC}"
    prompt_choice
    case "$CHOICE" in
        1) DEFAULT_EDITOR="code" ;;
        2) DEFAULT_EDITOR="nano" ;;
        3) DEFAULT_EDITOR="vim" ;;
        4) DEFAULT_EDITOR="nvim" ;;
        5) DEFAULT_EDITOR="vi" ;;
        6) DEFAULT_EDITOR="micro" ;;
        7) prompt_input "Enter editor name"; DEFAULT_EDITOR="$INPUT" ;;
        *) DEFAULT_EDITOR="nano" ;;
    esac

    # Theme
    echo -e "\n  ${BOLD}Color theme:${NC}"
    echo -e "  ${GR}1) Default (cyan)  2) Green  3) Magenta  4) No color${NC}"
    prompt_choice
    case "$CHOICE" in
        1) DEFAULT_THEME="default" ;;
        2) DEFAULT_THEME="green" ;;
        3) DEFAULT_THEME="magenta" ;;
        4) DEFAULT_THEME="none" ;;
        *) DEFAULT_THEME="default" ;;
    esac

    # Auto-clean
    echo -e "\n  ${BOLD}Auto-clean after upgrades?${NC} ${GR}[y/n]${NC}"
    read -rp "  › " _r
    [[ "${_r,,}" == "n" ]] && AUTO_CLEAN="false" || AUTO_CLEAN="true"

    # Backup location
    echo -e "\n  ${BOLD}Backup directory:${NC} ${GR}(default: $HOME/.aenux-backups)${NC}"
    prompt_input "Enter path or press Enter for default"
    [[ -n "$INPUT" ]] && BACKUP_LOCATION="$INPUT" || BACKUP_LOCATION="$HOME/.aenux-backups"

    # Write config
    cat > "$CONFIG_FILE" << EOF
# AENUX Configuration
BACKUP_BEFORE_UPGRADE=true
AUTO_CLEAN=${AUTO_CLEAN}
SHOW_TIPS=true
DRY_RUN=false
DEFAULT_EDITOR=${DEFAULT_EDITOR}
DEFAULT_SHELL=/bin/bash
DEFAULT_THEME=${DEFAULT_THEME}
BACKUP_LOCATION=${BACKUP_LOCATION}
EOF

    source "$CONFIG_FILE" 2>/dev/null || true
    mkdir -p "$BACKUP_LOCATION"
    
    # Verify editor exists
    if ! command -v "$DEFAULT_EDITOR" &>/dev/null; then
        warn "Editor '$DEFAULT_EDITOR' not found on your system."
        confirm "Install it now via package manager?" && {
            need_root
            run_spin "Installing $DEFAULT_EDITOR..." pm_run install "$DEFAULT_EDITOR" || \
                warn "Install failed. You can change the editor later in Settings."
        }
    fi
    
    ok "AENUX configured! Settings saved to $CONFIG_FILE"
    log INFO "First-run wizard completed"
    hist "First-run setup wizard completed"
    pause
}

# ───────────────────────────────────────────────────────────────────────
# THEME ENGINE
# ───────────────────────────────────────────────────────────────────────
apply_theme() {
    case "${DEFAULT_THEME:-default}" in
        green)    ACCENT="${G}";  ACCENT2="${C}" ;;
        magenta)  ACCENT="${M}";  ACCENT2="${Y}" ;;
        none)     ACCENT="";      ACCENT2=""; C=""; G=""; Y=""; B=""; M=""; R=""; W=""; GR=""; DIM=""; BOLD=""; NC="" ;;
        *)        ACCENT="${C}";  ACCENT2="${M}" ;;
    esac
}

