               grep -E "^(MemTotal|MemFree|MemAvailable|SwapTotal|SwapFree)" /proc/meminfo | \
                   awk '{printf "  %-20s %s\n", $1, $2" "$3}' ;;
            3) echo ""
               echo -e "  ${BOLD}── Disk Usage ──${NC}"
               df -h --output=target,fstype,size,used,avail,pcent 2>/dev/null | \
                   grep -Ev "^(tmpfs|devtmpfs|squashfs|efivarfs|cgroupfs|sysfs|proc|devpts|hugetlbfs|mqueue|debugfs|tracefs|securityfs|fusectl|binfmt_misc|configfs|none)" | \
                   awk '{print "  "$0}'
               echo ""
               echo -e "  ${BOLD}── Block Devices ──${NC}"
               lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL,MOUNTPOINT | awk '{print "  "$0}' ;;
            4) echo ""
               if command -v lspci &>/dev/null; then
                   lspci | grep -iE "vga|3d|display|gpu" | awk '{print "  "$0}'
               else warn "lspci not found. Install pciutils."; fi
               if command -v nvidia-smi &>/dev/null; then echo ""; nvidia-smi; fi ;;
            5) echo ""
               if command -v lsusb &>/dev/null; then lsusb | awk '{print "  "$0}'
               else warn "lsusb not found. Install usbutils."; fi ;;
            6) echo ""
               if command -v lspci &>/dev/null; then lspci | awk '{print "  "$0}'
               else warn "lspci not found. Install pciutils."; fi ;;
            7) echo ""
               if ls /sys/class/power_supply/BAT* &>/dev/null; then
                   for bat in /sys/class/power_supply/BAT*; do
                       echo -e "  ${BOLD}$(basename $bat):${NC}"
                       [[ -f "$bat/status" ]]   && echo -e "    Status:   $(cat $bat/status)"
                       [[ -f "$bat/capacity" ]] && echo -e "    Capacity: $(cat $bat/capacity)%"
                       [[ -f "$bat/technology" ]] && echo -e "    Type:     $(cat $bat/technology)"
                   done
               else warn "No battery detected."; fi ;;
            8) echo ""
               if command -v sensors &>/dev/null; then sensors
               elif command -v acpi &>/dev/null; then acpi -t
               elif [[ -d /sys/class/hwmon ]]; then
                   for hwmon in /sys/class/hwmon/hwmon*; do
                       local name; name=$(cat "$hwmon/name" 2>/dev/null || echo "hwmon")
                       echo -e "  ${BOLD}$name${NC}"
                       for temp in "$hwmon"/temp*_input; do
                           [[ -f "$temp" ]] && printf "  %s: %s°C\n" "$(basename $temp)" "$(awk '{printf "%.1f", $1/1000}' $temp)"
                       done
                   done
               else warn "Install lm-sensors: aenux install lm-sensors"; fi ;;
            9) echo ""
               if   command -v fastfetch   &>/dev/null; then fastfetch
               elif command -v hyfetch     &>/dev/null; then hyfetch
               elif command -v neofetch    &>/dev/null; then neofetch
               elif command -v macchina    &>/dev/null; then macchina
               elif command -v pfetch      &>/dev/null; then pfetch
               elif command -v cpufetch    &>/dev/null; then cpufetch
               elif command -v screenfetch &>/dev/null; then screenfetch
               elif command -v inxi        &>/dev/null; then inxi -Fxz
               else
                   warn "No fetch tool found. Install one:"
                   echo -e "  ${DIM}fastfetch / hyfetch / neofetch / macchina / pfetch / screenfetch / inxi${NC}"
                   echo -e "  ${DIM}Example: aenux install fastfetch${NC}"
               fi ;;
            a) show_system_about ;;
            0) return ;;
            *) warn "Invalid choice." ;;
        esac
        pause
    done
}

