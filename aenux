svc_action() {
    local action=$1 svc=$2
    if command -v systemctl &>/dev/null; then
        systemctl "$action" "$svc" && ok "[$svc] $action" || fail "Failed to $action '$svc'"
    elif command -v service &>/dev/null; then
        service "$svc" "$action" && ok "[$svc] $action" || fail "Failed."
    else
        fail "No init system found."
    fi
    log INFO "Service $svc: $action"; hist "service: $svc $action"
}

