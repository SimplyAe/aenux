do_deep_clean() {
    info "Deep cleaning system..."
    run_spin "Cleaning package cache..." pm_run clean
    if command -v journalctl &>/dev/null; then
        run_spin "Trimming journal (3 days)..." journalctl --vacuum-time=3d
    fi
    run_spin "Clearing /tmp and /var/tmp..." bash -c 'rm -rf /tmp/* /var/tmp/* 2>/dev/null; true'
    run_spin "Removing old log archives..." bash -c 'find /var/log -type f \( -name "*.gz" -o -name "*.log.*" \) -mtime +14 -delete 2>/dev/null; true'
    run_spin "Clearing thumbnail cache..." bash -c 'rm -rf ~/.cache/thumbnails/* 2>/dev/null; true'
    local avail; avail=$(df -h / | awk 'NR==2{print $4}')
    ok "Deep clean complete. Free space on /: ${avail}"    hist "deep-clean"
    log INFO "Deep clean completed"
}

do_auto_upgrade() {
    info "Smart auto-upgrade starting..."
    local avail_kb; avail_kb=$(df / | awk 'NR==2{print $4}')
    if [[ $avail_kb -lt 524288 ]]; then
        warn "Low disk space (<512MB detected). Running clean first..."
        do_deep_clean
    fi
    local count; count=$(pm_run check 2>/dev/null | tr -d '[:space:]' || echo 0)
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    if [[ "$count" -eq 0 ]]; then
        ok "System is already up to date."
        return
    fi
    info "$count package(s) to upgrade."
    [[ "$BACKUP_BEFORE_UPGRADE" == "true" ]] && backup_state
    run_spin "Upgrading system..." pm_run upgrade
    [[ "$AUTO_CLEAN" == "true" ]] && run_spin "Cleaning up..." pm_run clean
    ok "Auto-upgrade complete ($count packages)."
    hist "auto-upgrade: $count packages"
    log INFO "Auto-upgrade: $count packages"
}

do_optimize() {
    info "Optimizing system performance..."
    sync
    echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true
    sysctl -qw vm.swappiness=10 2>/dev/null || true
    sysctl -qw vm.vfs_cache_pressure=50 2>/dev/null || true
    if command -v fstrim &>/dev/null; then
        run_spin "Trimming SSDs (fstrim)..." fstrim -av
    fi
    ok "System optimized."
    local mem; mem=$(free -h | awk '/Mem/{print $7}')
    info "Available memory now: $mem"
    hist "optimize"
}

do_fsck() {
    warn "fsck must run on unmounted filesystems."
    info "Scheduling fsck check on next reboot for /..."
    if touch /forcefsck 2>/dev/null; then
        ok "Scheduled via /forcefsck."
    else
        info "Try: tune2fs -c 1 /dev/<device>  or  systemctl enable systemd-fsck-root"
    fi
}

do_initramfs() {
    if command -v update-initramfs &>/dev/null; then
        run_spin "Rebuilding initramfs..." update-initramfs -u -k all
    elif command -v mkinitcpio &>/dev/null; then
        run_spin "Rebuilding (mkinitcpio)..." mkinitcpio -P
    elif command -v dracut &>/dev/null; then
        run_spin "Rebuilding (dracut)..." dracut --regenerate-all --force
    else
        warn "No initramfs tool found (tried: update-initramfs, mkinitcpio, dracut)."
        return
    fi
    ok "Initramfs rebuilt."
    hist "rebuild-initramfs"
}

do_journal_clean() {
    prompt_input "Keep logs for how many days? (default: 3)"
    local days="${INPUT:-3}"
    run_spin "Vacuuming journal..." journalctl --vacuum-time="${days}d"
    ok "Journal cleaned (kept last ${days} days)."
    hist "journal-clean: ${days}d"
}

do_purge_kernels() {
    local pm; pm=$(detect_pm)
    case "$pm" in
        apt-get)
            info "Current kernel: $(uname -r)"
            info "Installed linux-image packages:"
            dpkg -l | grep linux-image | awk '{print "  " $2}'
            echo ""
            confirm "Remove old kernels (keeps running kernel)?" || return
            run_spin "Removing old kernels..." bash -c \
                'apt-get purge -y $(dpkg -l "linux-image-*" | awk "/^ii/{print \$2}" | grep -v "$(uname -r)" | grep -v "linux-image-generic") 2>/dev/null; apt-get autoremove -y'
            ok "Old kernels purged."; hist "purge-kernels" ;;
        dnf|yum)
            run_spin "Removing old kernels..." dnf remove -y --oldinstallonly --setopt installonly_limit=2
            ok "Old kernels removed."; hist "purge-kernels" ;;
        pacman)
            info "Installed kernels:"; pacman -Qq | grep "^linux" | head -20
            warn "Remove manually: sudo pacman -Rns <kernel-package>" ;;
        *) warn "Kernel purge not automated for your package manager." ;;
    esac
}

schedule_task() {
    local task="$1"
    echo ""
    info "Schedule auto-$task via:"
    echo -e "  ${G}1)${NC}  cron"
    echo -e "  ${B}2)${NC}  systemd timer"
    echo -e "  ${GR}0)${NC}  Cancel"
    prompt_choice
    case "$CHOICE" in
        1) schedule_cron "$task" ;;
        2) schedule_systemd_timer "$task" ;;
        0) return ;;
    esac
}

schedule_cron() {
    local task="$1"
    echo ""
    echo -e "  ${BOLD}When should it run?${NC}"
    echo -e "  ${G}1)${NC} Daily at 03:00"
    echo -e "  ${B}2)${NC} Weekly (Sunday 03:00)"
    echo -e "  ${Y}3)${NC} Custom cron expression"
    prompt_choice
    local cron_expr
    case "$CHOICE" in
        1) cron_expr="0 3 * * *" ;;
        2) cron_expr="0 3 * * 0" ;;
        3) prompt_input "Cron expression (e.g. 0 3 * * *)"; cron_expr="$INPUT" ;;
        *) warn "Cancelled."; return ;;
    esac
    local cmd="$SCRIPT_PATH $task"
    (crontab -l 2>/dev/null; echo "$cron_expr root $cmd") | crontab -
    ok "Cron job added: [$cron_expr] $cmd"
    hist "schedule-cron: $task $cron_expr"
}

schedule_systemd_timer() {
    local task="$1"
    local unit_name="aenux-${task}"
    echo ""
    echo -e "  ${BOLD}Run every:${NC}"
    echo -e "  ${G}1)${NC} Daily"
    echo -e "  ${B}2)${NC} Weekly"
    prompt_choice
    local on_calendar
    case "$CHOICE" in
        1) on_calendar="daily" ;;
        2) on_calendar="weekly" ;;
        *) warn "Cancelled."; return ;;
    esac

    cat > "/etc/systemd/system/${unit_name}.service" << EOF
[Unit]
Description=AENUX auto-${task}

[Service]
Type=oneshot
ExecStart=${SCRIPT_PATH} ${task}
EOF

    cat > "/etc/systemd/system/${unit_name}.timer" << EOF
[Unit]
Description=AENUX auto-${task} timer

[Timer]
OnCalendar=${on_calendar}
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl daemon-reload
    systemctl enable --now "${unit_name}.timer"
    ok "Systemd timer created and enabled: ${unit_name}.timer"
    hist "schedule-systemd: $task $on_calendar"
}

