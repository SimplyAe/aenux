        case "$CHOICE" in
            1) toggle_cfg "BACKUP_BEFORE_UPGRADE" ;;
            2) toggle_cfg "AUTO_CLEAN" ;;
            3) toggle_cfg "SHOW_TIPS" ;;
            4) toggle_cfg "DRY_RUN" ;;
            5) echo -e "\n  ${GR}1) code  2) nano  3) vim  4) nvim  5) vi  6) micro  7) other${NC}"
               prompt_choice
               local ed
               case "$CHOICE" in
                   1) ed="code" ;; 2) ed="nano" ;; 3) ed="vim" ;; 4) ed="nvim" ;; 5) ed="vi" ;; 6) ed="micro" ;;
                   7) prompt_input "Editor name"; ed="$INPUT" ;;
                   *) ed="$DEFAULT_EDITOR" ;;
               esac
               set_cfg "DEFAULT_EDITOR" "$ed"; ok "Editor set to $ed" ;;
            6) echo -e "\n  ${GR}1) default  2) green  3) magenta  4) none${NC}"
               prompt_choice
               local th
               case "$CHOICE" in
                   1) th="default" ;; 2) th="green" ;; 3) th="magenta" ;; 4) th="none" ;; *) th="default" ;;
               esac
               set_cfg "DEFAULT_THEME" "$th"; ok "Theme set to $th" ;;
            7) prompt_input "New backup directory path"
               mkdir -p "$INPUT" && set_cfg "BACKUP_LOCATION" "$INPUT" && ok "Backup dir set to $INPUT." || fail "Could not create directory." ;;
            8) ${DEFAULT_EDITOR:-nano} "$CONFIG_FILE"; reload_config ;;
            9) first_run_wizard ;;
            a) update_aenux ;;
            0) return ;;
            *) warn "Invalid choice." ;;
        esac
        pause
    done
}

toggle_cfg() {
    local key="$1"
    reload_config
    local current; current=$(grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | cut -d= -f2)
    local new_val; [[ "$current" == "true" ]] && new_val="false" || new_val="true"
    set_cfg "$key" "$new_val"
    ok "${key} → ${new_val}"
}

set_cfg() {
    local key="$1" val="$2"
    if grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${val}|" "$CONFIG_FILE"
    else
        echo "${key}=${val}" >> "$CONFIG_FILE"
    fi
    reload_config
}

