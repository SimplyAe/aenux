                    2) need_root; svc_action stop "$svc" ;;
                    3) need_root; svc_action restart "$svc" ;;
                    4) need_root; svc_action enable "$svc" ;;
                    5) need_root; svc_action disable "$svc" ;;
                    6) svc_action status "$svc" ;;
                esac ;;
            7) echo ""
               if command -v systemctl &>/dev/null; then
                   systemctl list-units --type=service --state=running --no-pager | head -40
               else
                   service --status-all 2>&1 | grep "+" | head -40
               fi ;;
            8) echo ""
               if command -v systemctl &>/dev/null; then
                   systemctl --failed --no-pager
               else
                   warn "Failed service listing requires systemd."
               fi ;;
