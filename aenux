# ───────────────────────────────────────────────────────────────────────
# MENU DRAWING
# ───────────────────────────────────────────────────────────────────────
draw_menu() {
    local title="$1"; shift
    echo -e "  ${C}${BOLD}┌─── ${title}${NC}"
    for opt in "$@"; do
        echo -e "  ${C}│${NC}  $opt"
    done
    echo -e "  ${C}└──────────────────────────────────────────${NC}\n"
}

section() {
    echo -e "\n  ${C}${BOLD}── $* ──${NC}\n"
}

# ───────────────────────────────────────────────────────────────────────
# DISTRO & PACKAGE MANAGER DETECTION
# ───────────────────────────────────────────────────────────────────────
get_distro_name() {
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release 2>/dev/null
        echo "${PRETTY_NAME:-${NAME:-Unknown}}"
    elif [[ -f /etc/issue ]]; then
        head -1 /etc/issue | tr -d '\n\l'
    else
        uname -s
    fi
}

detect_pm() {
    for pm in apt-get dnf yum zypper pacman apk xbps-install nix-env emerge slackpkg swupd urpmi; do
        command -v "$pm" &>/dev/null && echo "$pm" && return
    done
    echo "unknown"
}

detect_secondary_pms() {
    local found=()
    for pm in snap flatpak brew pip3 npm cargo gem; do
        command -v "$pm" &>/dev/null && found+=("$pm")
    done
    echo "${found[*]}"
}

# ───────────────────────────────────────────────────────────────────────
# PACKAGE MANAGER ABSTRACTION
# ───────────────────────────────────────────────────────────────────────
pm_run() {
    local action=$1; shift
    local pm; pm=$(detect_pm)

    # Dry-run intercept for destructive actions
    if [[ "$DRY_RUN" == "true" ]] && [[ "$action" =~ ^(upgrade|install|remove|fix|clean)$ ]]; then
        warn "[DRY-RUN] Would run: $pm $action $*"
        log INFO "[DRY-RUN] $pm $action $*"
        return 0
    fi

    case "$pm" in
        apt-get)
            case "$action" in
                update)   apt-get update -qq ;;
                upgrade)  DEBIAN_FRONTEND=noninteractive apt-get upgrade -y && apt-get dist-upgrade -y ;;
                install)  DEBIAN_FRONTEND=noninteractive apt-get install -y "$@" ;;
                remove)   apt-get remove -y "$@" && apt-get autoremove -y ;;
                search)   apt-cache search "$@" ;;
                list)     dpkg -l | awk '/^ii/{print $2}' ;;
                clean)    apt-get autoremove -y && apt-get autoclean && apt-get clean ;;
                fix)      dpkg --configure -a && apt-get install -f -y ;;
                info)     apt-cache show "$@" 2>/dev/null ;;
                check)    apt list --upgradable 2>/dev/null | grep -c upgradable || echo 0 ;;
                owns)     dpkg -S "$@" 2>/dev/null ;;
                recent)   grep "install " /var/log/dpkg.log 2>/dev/null | tail -20 ;;
                hold)     apt-mark hold "$@" ;;
                unhold)   apt-mark unhold "$@" ;;
                held)     apt-mark showhold ;;
                dryupgrade) apt-get upgrade --dry-run ;;
            esac ;;
        dnf)
            case "$action" in
                update)   dnf check-update -q || true ;;
                upgrade)  dnf upgrade -y ;;
                install)  dnf install -y "$@" ;;
                remove)   dnf remove -y "$@" && dnf autoremove -y ;;
                search)   dnf search "$@" ;;
                list)     dnf list installed 2>/dev/null | awk 'NR>1{print $1}' ;;
                clean)    dnf autoremove -y && dnf clean all ;;
                fix)      dnf distro-sync -y ;;
                info)     dnf info "$@" 2>/dev/null ;;
                check)    dnf list updates 2>/dev/null | grep -c "^[[:alnum:]]" || echo 0 ;;
                owns)     dnf provides "$@" 2>/dev/null ;;
                recent)   dnf history list 2>/dev/null | head -20 ;;
                hold)     dnf versionlock add "$@" 2>/dev/null || warn "Install dnf-plugin-core for versionlock" ;;
                unhold)   dnf versionlock delete "$@" 2>/dev/null ;;
                held)     dnf versionlock list 2>/dev/null ;;
                dryupgrade) dnf upgrade --dry-run ;;
            esac ;;
        yum)
            case "$action" in
                update)   yum check-update -q || true ;;
                upgrade)  yum update -y ;;
                install)  yum install -y "$@" ;;
                remove)   yum remove -y "$@" ;;
                search)   yum search "$@" ;;
                list)     rpm -qa --qf '%{NAME}\n' ;;
                clean)    yum clean all ;;
                fix)      yum distro-sync -y 2>/dev/null || yum update -y ;;
                info)     yum info "$@" 2>/dev/null ;;
                check)    yum list updates 2>/dev/null | grep -c "^[[:alnum:]]" || echo 0 ;;
                owns)     yum provides "$@" 2>/dev/null ;;
                recent)   yum history list 2>/dev/null | head -20 ;;
                hold)     yum versionlock add "$@" ;;
                unhold)   yum versionlock delete "$@" ;;
                held)     yum versionlock list ;;
                dryupgrade) yum update --assumeno ;;
            esac ;;
        zypper)
            case "$action" in
                update)   zypper refresh -q ;;
                upgrade)  zypper update -y ;;
                install)  zypper install -y "$@" ;;
                remove)   zypper remove -y "$@" ;;
                search)   zypper search "$@" ;;
                list)     zypper search --installed-only 2>/dev/null | awk 'NR>4{print $3}' ;;
                clean)    zypper clean --all ;;
                fix)      zypper verify -y ;;
                info)     zypper info "$@" 2>/dev/null ;;
                check)    zypper list-updates 2>/dev/null | grep -c "^v" || echo 0 ;;
                owns)     zypper search --provides "$@" ;;
                recent)   zypper history 2>/dev/null | head -20 ;;
                hold)     zypper addlock "$@" ;;
                unhold)   zypper removelock "$@" ;;
                held)     zypper locks ;;
                dryupgrade) zypper update --dry-run ;;
            esac ;;
        pacman)
            case "$action" in
                # Write operations — require sudo
                update)   sudo pacman -Sy --noconfirm -q ;;
                upgrade)  sudo pacman -Syu --noconfirm ;;
                install)  sudo pacman -S --noconfirm "$@" ;;
                remove)   sudo pacman -Rns --noconfirm "$@" ;;
                clean)    sudo pacman -Sc --noconfirm ;;
                fix)      sudo pacman -Syy --noconfirm ;;
                # Read-only — no sudo needed
                search)   pacman -Ss "$@" ;;
                list)     pacman -Qq ;;
                info)     pacman -Si "$@" 2>/dev/null ;;
                check)    pacman -Qu 2>/dev/null | wc -l || echo 0 ;;
                owns)     pacman -Qo "$@" 2>/dev/null ;;
                recent)   grep -E "installed|upgraded" /var/log/pacman.log 2>/dev/null | tail -20 ;;
                hold)     warn "Add to /etc/pacman.conf under IgnorePkg = <package>" ;;
                unhold)   warn "Remove from IgnorePkg in /etc/pacman.conf" ;;
                held)     grep "^IgnorePkg" /etc/pacman.conf 2>/dev/null || echo "  (none set)" ;;
                dryupgrade) pacman -Syu --print-format "  %n %v" --noconfirm 2>/dev/null ;;
            esac ;;
        apk)
            case "$action" in
                update)   apk update -q ;;
                upgrade)  apk upgrade ;;
                install)  apk add "$@" ;;
                remove)   apk del "$@" ;;
                search)   apk search "$@" ;;
                list)     apk list --installed 2>/dev/null | awk '{print $1}' ;;
                clean)    apk cache clean ;;
                fix)      apk fix ;;
                info)     apk info "$@" 2>/dev/null ;;
                check)    apk version 2>/dev/null | grep -c "<" || echo 0 ;;
                owns)     apk info --who-owns "$@" ;;
                recent)   apk log 2>/dev/null | tail -20 ;;
                hold)     apk add "$@=" ;;
                unhold)   warn "Remove version pin manually from /etc/apk/world" ;;
                held)     grep "=" /etc/apk/world 2>/dev/null ;;
                dryupgrade) apk upgrade --simulate ;;
            esac ;;
        xbps-install)
            case "$action" in
                update)   xbps-install -S -y 2>/dev/null || true ;;
                upgrade)  xbps-install -Su -y ;;
                install)  xbps-install -S "$@" ;;
                remove)   xbps-remove -R "$@" ;;
                search)   xbps-query -Rs "$@" ;;
                list)     xbps-query -l | awk '{print $2}' ;;
                clean)    xbps-remove -Oo -y ;;
                fix)      xbps-pkgdb -a ;;
                info)     xbps-query -RS "$@" ;;
                check)    xbps-install -Sun 2>/dev/null | wc -l || echo 0 ;;
                owns)     xbps-query -o "$@" ;;
                recent)   xbps-query -l | tail -20 ;;
                hold)     xbps-pkgdb -m hold "$@" ;;
                unhold)   xbps-pkgdb -m unhold "$@" ;;
                held)     xbps-query -l | grep hold ;;
                dryupgrade) xbps-install -Sun ;;
            esac ;;
        nix-env)
            case "$action" in
                update)   nix-channel --update ;;
                upgrade)  nix-env -u '*' ;;
                install)  nix-env -iA nixpkgs."$@" ;;
                remove)   nix-env -e "$@" ;;
                search)   nix-env -qaP "$@" ;;
                list)     nix-env -q ;;
                clean)    nix-collect-garbage -d ;;
                fix)      nix-store --verify --check-contents ;;
                info)     nix-env -qaP --description "$@" ;;
                check)    nix-env -qu 2>/dev/null | wc -l || echo 0 ;;
                owns)     nix-store -q --references "$@" ;;
                recent)   nix-env --list-generations | tail -10 ;;
                dryupgrade) nix-env -u '*' --dry-run ;;
            esac ;;
        emerge)
            case "$action" in
                update)   emerge --sync -q ;;
                upgrade)  emerge -uDU --keep-going @world ;;
                install)  emerge "$@" ;;
                remove)   emerge --depclean "$@" ;;
                search)   emerge --search "$@" ;;
                list)     qlist -Iv 2>/dev/null || equery list '*' ;;
                clean)    emerge --depclean -q ;;
                fix)      revdep-rebuild ;;
                info)     emerge -s "$@" ;;
                check)    emerge -puDU @world 2>/dev/null | grep -c "^\\[ebuild" || echo 0 ;;
                owns)     equery belongs "$@" ;;
                dryupgrade) emerge -pDUu @world ;;
            esac ;;
        slackpkg)
            case "$action" in
                update)   slackpkg update ;;
                upgrade)  slackpkg upgrade-all ;;
                install)  slackpkg install "$@" ;;
                remove)   slackpkg remove "$@" ;;
                search)   slackpkg search "$@" ;;
                list)     ls /var/log/packages/ ;;
                clean)    slackpkg clean-system ;;
                info)     slackpkg info "$@" ;;
                check)    slackpkg upgrade-all 2>/dev/null | grep -c "^Upgrading" || echo 0 ;;
            esac ;;
        swupd)
            case "$action" in
                update)   swupd update --dry-run ;;
                upgrade)  swupd update ;;
                install)  swupd bundle-add "$@" ;;
                remove)   swupd bundle-remove "$@" ;;
                search)   swupd search "$@" ;;
                list)     swupd bundle-list ;;
                clean)    swupd clean --all ;;
                fix)      swupd repair ;;
                info)     swupd bundle-info "$@" ;;
                check)    swupd update --dry-run 2>/dev/null | grep -c "^Update" || echo 0 ;;
            esac ;;
        *) die "No supported package manager found." ;;
    esac
}

# ───────────────────────────────────────────────────────────────────────
# MENU: PACKAGES (native)
# ───────────────────────────────────────────────────────────────────────
menu_packages() {
    while true; do
        banner
        draw_menu "📦  Package Manager" \
            "${G}1)${NC}  Install package(s)" \
            "${R}2)${NC}  Remove package(s)" \
            "${Y}3)${NC}  Update package lists" \
            "${C}4)${NC}  Upgrade all packages" \
            "${B}5)${NC}  Search for a package" \
            "${W}6)${NC}  Package info / details" \
            "${M}7)${NC}  List installed packages" \
            "${R}8)${NC}  Fix broken packages" \
            "${Y}9)${NC}  What provides a file/command?" \
            "${C}a)${NC}  Recently installed packages" \
            "${B}b)${NC}  Hold / pin a package version" \
            "${M}c)${NC}  Unhold a package" \
            "${W}d)${NC}  Show held/pinned packages" \
            "${G}e)${NC}  Dry-run: preview upgrades" \
            "${GR}0)${NC}  Back"
        prompt_choice

        case "$CHOICE" in
            1) need_root
               prompt_input "Package name(s)"
               run_spin "Installing ${INPUT}..." pm_run install $INPUT
               ok "Done."; hist "install: $INPUT" ;;
            2) need_root
               prompt_input "Package name(s) to remove"
               confirm "Remove '$INPUT'?" || { pause; continue; }
               run_spin "Removing ${INPUT}..." pm_run remove $INPUT
               ok "Removed."; hist "remove: $INPUT" ;;
            3) need_root
               run_spin "Updating package lists..." pm_run update
               ok "Package lists updated."; hist "update" ;;
            4) need_root
               [[ "$BACKUP_BEFORE_UPGRADE" == "true" ]] && backup_state
               run_spin "Upgrading all packages..." pm_run upgrade
               [[ "$AUTO_CLEAN" == "true" ]] && run_spin "Cleaning..." pm_run clean
               ok "System upgraded."; hist "upgrade" ;;
            5) prompt_input "Search query"
               echo ""; pm_run search "$INPUT" 2>/dev/null | head -50 ;;
            6) prompt_input "Package name"
               echo ""; pm_run info "$INPUT" 2>/dev/null ;;
            7) info "Installed packages (sorted):"; echo ""
               pm_run list 2>/dev/null | sort | column ;;
            8) need_root
               run_spin "Fixing broken packages..." pm_run fix
               ok "Done."; hist "fix-broken" ;;
            9) prompt_input "File or command (e.g. /usr/bin/python3)"
               echo ""; pm_run owns "$INPUT" 2>/dev/null ;;
            a) echo ""; pm_run recent 2>/dev/null ;;
            b) need_root
               prompt_input "Package to hold/pin"
               pm_run hold "$INPUT"
               ok "Package '$INPUT' held."; hist "hold: $INPUT" ;;
            c) need_root
               prompt_input "Package to unhold"
               pm_run unhold "$INPUT"
               ok "Unheld."; hist "unhold: $INPUT" ;;
            d) echo ""; pm_run held 2>/dev/null ;;
            e) echo ""
               info "Dry-run upgrade preview:"; echo ""
               pm_run dryupgrade 2>/dev/null ;;
