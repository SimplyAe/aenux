# ───────────────────────────────────────────────────────────────────────
# SELF-UPDATE
# ───────────────────────────────────────────────────────────────────────
update_aenux() {
    info "Checking for AENUX updates..."
    if ! command -v curl &>/dev/null && ! command -v wget &>/dev/null; then
        warn "curl or wget is required to update AENUX."
        return
    fi

    local tmp="/tmp/aenux_update"

    if command -v curl &>/dev/null; then
        curl -fsSL "$AENUX_REMOTE" -o "$tmp" 2>/dev/null
    else
        wget -qO "$tmp" "$AENUX_REMOTE" 2>/dev/null
    fi

    if [[ ! -s "$tmp" ]]; then
        warn "Could not fetch update (no internet or remote URL not configured)."
        info "To self-host updates, set AENUX_REMOTE in $CONFIG_FILE"
        rm -f "$tmp"
        return
    fi

    local remote_ver; remote_ver=$(grep "^VERSION=" "$tmp" | cut -d'"' -f2)

    if [[ "$remote_ver" == "$VERSION" ]]; then
        ok "Already on the latest version (v${VERSION})."
    elif [[ -n "$remote_ver" ]]; then
        info "New version available: v${remote_ver} (current: v${VERSION})"
        confirm "Update AENUX to v${remote_ver}?" || { rm -f "$tmp"; return; }
        chmod +x "$tmp"
        cp "$tmp" "$SCRIPT_PATH"
        ok "AENUX updated to v${remote_ver}. Restart to apply."
        hist "self-update: v$VERSION → v$remote_ver"
    fi
    rm -f "$tmp"
}

