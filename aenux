                   journalctl --no-pager -n 50 | awk '{print "  "$0}'
               elif [[ -f /var/log/syslog ]]; then
                   tail -50 /var/log/syslog | awk '{print "  "$0}'
               elif [[ -f /var/log/messages ]]; then
                   tail -50 /var/log/messages | awk '{print "  "$0}'
               else warn "No system log found."; fi ;;
            4) echo ""; dmesg | tail -40 | awk '{print "  "$0}' ;;
            5) echo ""
               if [[ -f /var/log/auth.log ]]; then
                   tail -40 /var/log/auth.log | awk '{print "  "$0}'
               elif [[ -f /var/log/secure ]]; then
                   tail -40 /var/log/secure | awk '{print "  "$0}'
               elif command -v journalctl &>/dev/null; then
                   journalctl -u ssh -u sshd -u sudo --no-pager -n 40 | awk '{print "  "$0}'
               else warn "No auth log found."; fi ;;
            6) echo ""
               if command -v journalctl &>/dev/null; then
                   journalctl -b --no-pager -n 50 | awk '{print "  "$0}'
               elif [[ -f /var/log/boot.log ]]; then
                   tail -50 /var/log/boot.log | awk '{print "  "$0}'
               else warn "No boot log found."; fi ;;
            7) confirm "Clear AENUX action history?" && > "$HISTORY_FILE" && ok "History cleared." ;;
            8) confirm "Clear AENUX log?" && > "$LOGFILE" && ok "Log cleared." ;;
            0) return ;;
            *) warn "Invalid choice." ;;
        esac
        pause
    done
}

