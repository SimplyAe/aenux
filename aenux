# ───────────────────────────────────────────────────────────────────────
# CLI MODE (non-interactive / scripting)
# ───────────────────────────────────────────────────────────────────────
cli_mode() {
    local cmd=$1; shift
    case "$cmd" in
        install|i)    need_root; pm_run install "$@"; ok "Done." ;;
        remove|rm)    need_root; pm_run remove "$@"; ok "Done." ;;
        update|up)    need_root; pm_run update; ok "Done." ;;
        upgrade|ug)   need_root; do_auto_upgrade ;;
        clean|c)      need_root; do_deep_clean ;;
        search|s)     pm_run search "$@" ;;
        list|ls)      pm_run list ;;
        info)         pm_run info "$@" ;;
        fix|f)        need_root; pm_run fix ;;
        optimize|opt) need_root; do_optimize ;;
        backup|bak)   backup_state ;;
        health|h)     menu_health ;;
        service|svc)  need_root; svc_action "$1" "$2" ;;
        update-self)  update_aenux ;;
        version|-v|--version) echo "AENUX v$VERSION" ;;
        help|--help|-h) show_cli_help ;;
        *)
            fail "Unknown command: $cmd"
            echo -e "  Run ${C}aenux help${NC} or just ${C}aenux${NC} for the interactive menu."
            exit 1 ;;
    esac
}

